---
// Pagefind-powered search modal. The Pagefind UI bundle and index live under
// /pagefind/ in the deployed site (generated by `npm run index:search` after
// `astro build`). In dev (`astro dev`) the bundle does not exist, so the UI
// shows a friendly placeholder instead of crashing.
---
<dialog
  id="search-dialog"
  class="backdrop:bg-black/40 backdrop:backdrop-blur-sm rounded-lg shadow-2xl p-0 w-full max-w-2xl max-h-[80vh] overflow-hidden bg-white"
>
  <div class="flex flex-col max-h-[80vh]">
    <div class="flex items-center justify-between border-b border-gray-200 px-4 py-2">
      <span class="text-xs font-semibold uppercase tracking-wider text-gray-500">検索</span>
      <button
        type="button"
        id="search-dialog-close"
        aria-label="閉じる"
        class="text-gray-500 hover:text-gray-900 text-xl leading-none px-2 py-1"
      >×</button>
    </div>
    <div id="pagefind-container" class="flex-1 overflow-y-auto p-3"></div>
    <div class="border-t border-gray-200 px-4 py-2 text-[11px] text-gray-500 flex gap-3">
      <span><kbd class="px-1 border border-gray-300 rounded bg-gray-50">Esc</kbd> 閉じる</span>
      <span><kbd class="px-1 border border-gray-300 rounded bg-gray-50">Ctrl</kbd>+<kbd class="px-1 border border-gray-300 rounded bg-gray-50">K</kbd> 開く</span>
    </div>
  </div>
</dialog>

<style is:global>
  /* Pagefind UI overrides — match site accent (Tailwind accent.700 = #00524b) */
  #pagefind-container {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #00524b;
    --pagefind-ui-text: #1f2937;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: #f3f4f6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: inherit;
  }
  #pagefind-container .pagefind-ui__search-input {
    font-weight: 500;
  }
  #pagefind-container .pagefind-ui__result-link {
    color: #00524b;
  }
</style>

<script>
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
  const container = document.getElementById('pagefind-container');
  const closeBtn = document.getElementById('search-dialog-close');

  let uiLoaded = false;
  let loadingPromise: Promise<void> | null = null;

  async function ensurePagefindUI() {
    if (uiLoaded || !container) return;
    if (loadingPromise) return loadingPromise;
    loadingPromise = (async () => {
      try {
        // Load the bundled Pagefind UI from the site root. This file is
        // produced by `pagefind --site dist` and only exists in production
        // builds.
        await new Promise<void>((resolve, reject) => {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = '/pagefind/pagefind-ui.css';
          link.onload = () => resolve();
          link.onerror = () => reject(new Error('pagefind-ui.css not found'));
          document.head.appendChild(link);
        });
        const url = '/pagefind/pagefind-ui.js';
        await import(/* @vite-ignore */ url);
        const PagefindUI = (window as any).PagefindUI;
        new PagefindUI({
          element: '#pagefind-container',
          showSubResults: true,
          resetStyles: false,
          translations: {
            placeholder: 'ハンドブックを検索…',
            clear_search: 'クリア',
            load_more: 'さらに読み込む',
            search_label: 'このサイトを検索',
            filters_label: 'フィルター',
            zero_results: '[SEARCH_TERM] の検索結果はありません',
            many_results: '[SEARCH_TERM] の検索結果 [COUNT] 件',
            one_result: '[SEARCH_TERM] の検索結果 [COUNT] 件',
            alt_search: '[SEARCH_TERM] の検索結果はありません。代わりに [DIFFERENT_TERM] を表示しています',
            search_suggestion: '[SEARCH_TERM] の検索結果はありません。次のいずれかをお試しください: [DIFFERENT_TERMS]',
            searching: '[SEARCH_TERM] を検索中…',
          },
        });
        uiLoaded = true;
      } catch (err) {
        container.innerHTML =
          '<div class="text-sm text-gray-600 p-4">検索インデックスは本番ビルド時にのみ生成されます (<code>npm run build</code>)。dev サーバーでは利用できません。</div>';
      }
    })();
    return loadingPromise;
  }

  function openDialog() {
    if (!dialog) return;
    if (!dialog.open) dialog.showModal();
    void ensurePagefindUI().then(() => {
      const input = dialog.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
      input?.focus();
    });
  }

  function closeDialog() {
    if (dialog?.open) dialog.close();
  }

  closeBtn?.addEventListener('click', closeDialog);
  dialog?.addEventListener('click', (e) => {
    // Click on backdrop closes
    if (e.target === dialog) closeDialog();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      openDialog();
    }
  });

  // Expose for sidebar trigger
  (window as any).__openSearchDialog = openDialog;
</script>
