---
// Header intentionally uses plain text (no GitLab logo / Tanuki) to avoid
// trademark confusion. The "非公式" badge is always visible.
---
<header class="bg-accent-700 text-white">
  <div class="w-full px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-4">
    <a href="/" class="no-underline flex items-baseline gap-3 text-white hover:text-white">
      <span class="text-xl font-semibold tracking-tight">Handbook JA</span>
      <span class="text-[11px] font-medium uppercase tracking-wider border border-white/50 rounded px-1.5 py-0.5">
        非公式 / Unofficial
      </span>
    </a>
    <nav class="text-sm flex items-center gap-5">
      <a href="/handbook/" class="text-white/90 hover:text-white no-underline">Handbook</a>
      <a href="/about/" class="text-white/90 hover:text-white no-underline">このサイトについて</a>
      <a
        href="https://handbook.gitlab.com/"
        rel="external noopener"
        class="text-white/90 hover:text-white no-underline"
      >原文 (EN)</a>
    </nav>
  </div>
</header>
