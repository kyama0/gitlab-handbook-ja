---
// Header intentionally uses plain text (no GitLab logo / Tanuki) to avoid
// trademark confusion. The "非公式" badge is always visible.
---
<header class="border-b border-gray-200 bg-white">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="no-underline flex items-baseline gap-2">
      <span class="text-lg font-semibold text-gray-900">Handbook JA</span>
      <span class="text-xs font-medium text-accent-600 border border-accent-500 rounded px-1.5 py-0.5">
        非公式 / Unofficial
      </span>
    </a>
    <nav class="text-sm flex gap-4">
      <a href="/handbook/">Handbook</a>
      <a href="/about/">このサイトについて</a>
      <a href="https://handbook.gitlab.com/" rel="external noopener">原文 (EN)</a>
    </nav>
  </div>
</header>
