---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  upstreamPath?: string;
  wide?: boolean;
}

const { title, description, upstreamPath, wide = false } = Astro.props;
const siteTitle = 'GitLab Handbook 非公式日本語訳';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const upstreamBase = import.meta.env.PUBLIC_UPSTREAM_BASE ?? 'https://handbook.gitlab.com';
const upstreamUrl = upstreamPath ? new URL(upstreamPath, upstreamBase).toString() : null;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    {upstreamUrl && <link rel="alternate" hreflang="en" href={upstreamUrl} />}
    <link rel="alternate" hreflang="ja" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:locale" content="ja_JP" />
    <meta name="robots" content="index,follow" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class={`flex-1 w-full py-8 ${wide ? 'px-4 sm:px-6 lg:px-8' : 'max-w-5xl mx-auto px-4'}`}>
      <slot />
    </main>
    <Footer upstreamUrl={upstreamUrl} />
  </body>
</html>
