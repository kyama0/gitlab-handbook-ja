{
  "name": "gitlab-handbook-ja",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Unofficial Japanese translation of the GitLab Handbook",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "sync:upstream": "tsx scripts/sync-upstream.ts",
    "upload:images": "tsx --env-file-if-exists=.env scripts/upload-images-r2.ts",
    "check:staleness": "tsx scripts/check-staleness.ts",
    "transform:shortcodes": "tsx scripts/transform-shortcodes.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^5.1.5",
    "astro": "^6.1.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@aws-sdk/client-s3": "^3.650.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "yaml": "^2.8.3"
  }
}
