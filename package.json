{
  "name": "gitlab-handbook-ja",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Unofficial Japanese translation of the GitLab Handbook",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npm run index:search",
    "index:search": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "sync:upstream": "tsx scripts/sync-upstream.ts",
    "upload:images": "tsx --env-file-if-exists=.env scripts/upload-images-r2.ts",
    "check:staleness": "tsx scripts/check-staleness.ts",
    "transform:shortcodes": "tsx scripts/transform-shortcodes.ts"
  },
  "dependencies": {
    "@akebifiky/remark-simple-plantuml": "^1.0.2",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/sitemap": "^3.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.10",
    "mermaid": "^11.14.0",
    "remark-cjk-friendly": "^2.0.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@types/node": "^25.6.0",
    "pagefind": "^1.5.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "yaml": "^2.8.3"
  }
}
